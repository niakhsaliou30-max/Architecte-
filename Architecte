<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Saliou Architecture</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

  <!-- ===== NAVBAR ===== -->
  <header>
    <nav class="navbar">
      <h1 class="logo">Saliou Archi</h1>
      <ul class="nav-links">
        <li><a href="#home">Accueil</a></li>
        <li><a href="#about">À propos</a></li>
        <li><a href="#projects">Projets</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <!-- ===== HERO ===== -->
  <section id="home" class="hero">
    <h2>Construire le futur avec élégance</h2>
    <p>Nous créons des designs modernes et durables pour vos projets.</p>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="about">
    <h2>À propos</h2>
    <p>
      Saliou Architecture est une entreprise spécialisée dans la conception
      moderne, innovante et durable des bâtiments.
    </p>
  </section>

  <!-- ===== PROJECTS ===== -->
  <section id="projects" class="projects">
    <h2>Nos Projets</h2>
    <div class="gallery">
      <img src="https://picsum.photos/300/200?1">
      <img src="https://picsum.photos/300/200?2">
      <img src="https://picsum.photos/300/200?3">
      <img src="https://picsum.photos/300/200?4">
    </div>
  </section>

  <!-- ===== CONTACT ===== -->
  <section id="contact" class="contact">
    <h2>Contact</h2>
    <form id="contactForm">
      <input type="text" placeholder="Nom" required>
      <input type="email" placeholder="Email" required>
      <textarea placeholder="Message" required></textarea>
      <button type="submit">Envoyer</button>
    </form>
    <p id="message"></p>
  </section>

  <script src="script.js"></script>
</body>
</html>
